{
  "type": "object",
  "description": "Get a single dependency vulnerability alert from Dependabot for a repository via GitHub REST.",
  "properties": {
    "owner": {
      "type": "string",
      "description": "Repository owner."
    },
    "repo": {
      "type": "string",
      "description": "Repository name."
    },
    "alert_number": {
      "type": "integer",
      "description": "Dependabot alert number."
    }
  },
  "required": ["owner", "repo", "alert_number"],
  "additionalProperties": false
}
