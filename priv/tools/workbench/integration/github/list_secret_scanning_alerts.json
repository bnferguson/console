{
  "type": "object",
  "description": "List secret scanning alerts for a repository via GitHub REST.",
  "properties": {
    "owner": {
      "type": "string",
      "description": "Repository owner."
    },
    "repo": {
      "type": "string",
      "description": "Repository name."
    },
    "state": {
      "type": "string",
      "enum": ["open", "resolved"],
      "description": "Filter alerts by state."
    },
    "secret_type": {
      "type": "string",
      "description": "Filter by secret type, such as github_personal_access_token."
    },
    "resolution": {
      "type": "string",
      "description": "Filter resolved alerts by resolution."
    },
    "before": {
      "type": "string",
      "description": "Cursor for results before this value."
    },
    "after": {
      "type": "string",
      "description": "Cursor for results after this value."
    },
    "per_page": {
      "type": "integer",
      "description": "Results per page."
    }
  },
  "required": ["owner", "repo"],
  "additionalProperties": false
}
