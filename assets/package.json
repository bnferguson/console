    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "15.15.0",
    "graphql-tag": "2.12.7",
    "husky": "8.0.3",
    "jsdom": "29.1.1",
    "jwt-decode": "4.0.0",
    "lint-staged": "16.4.0",
    "npm-run-all2": "5.0.2",
    "prettier": "3.9.4",
    "stylelint": "15.11.0",
    "type-fest": "4.41.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.63.0",
    "vite": "7.3.6",
    "vite-bundle-visualizer": "1.2.1",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.7"
  },
  "lint-staged": {
    "./src/**/*.{js,jsx,ts,tsx,graphql,md}": "prettier --write",
    "./design-system/**/*.{js,jsx,ts,tsx,md,mdx}": "prettier --write"
  },
  "resolutions": {
    "elkjs": "0.11.0",
    "shell-quote": "1.8.4"
  }
