{
  "name": "console",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "design-system"
  ],
  "type": "module",
  "scripts": {
    "start": "vite",
    "start:dev": "BASE_URL=console.plrl-dev-aws.onplural.sh yarn start",
    "start:cd": "BASE_URL=console.plrldemo.onplural.sh yarn start",
    "start:prod": "VITE_PROD_SECRET_KEY=1234567890 vite build && BASE_URL=console.plrldemo.onplural.sh vite preview",
    "design-system:start": "yarn workspace @pluralsh/design-system start",
    "build": "yarn design-system:build && tsc --build && vite build",
    "build:no-ds": "tsc --build && vite build",
    "build:no-tsc": "vite build",
    "design-system:build": "yarn workspace @pluralsh/design-system build",
    "design-system:build:watch": "yarn workspace @pluralsh/design-system build:watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "design-system:test": "yarn workspace @pluralsh/design-system test",
    "lint": "run-p lint:format lint:js lint:css design-system:lint",
    "lint:format": "prettier --check ./src",
    "lint:js": "eslint ./src",
    "lint:css": "stylelint src/**/*.css",
    "design-system:lint": "yarn workspace @pluralsh/design-system lint",
    "fix": "run-s fix:js fix:css",
    "fix:format": "prettier --write ./src",
    "fix:js": "eslint ./src --fix",
    "fix:css": "stylelint src/**/*.css --fix",
    "graphql:codegen": "graphql-codegen --config codegen.yml",
    "openapi:codegen": "openapi-ts -i ./schema/swagger.json -o ./src/generated/kubernetes -p @tanstack/react-query -p @hey-api/client-axios",
    "analyze": "vite-bundle-visualizer -o stats.html"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "packageManager": "yarn@3.6.0",
  "dependencies": {
    "@algolia/client-search": "5.55.1",
    "@apollo/client": "3.14.1",
    "@docsearch/js": "4.6.3",
    "@docsearch/react": "4.6.3",
    "@emotion/is-prop-valid": "1.4.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
