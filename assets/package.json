    "@nivo/line": "0.99.0",
    "@nivo/pie": "0.99.0",
    "@nivo/radial-bar": "0.99.0",
    "@nivo/tooltip": "0.99.0",
    "@nivo/treemap": "0.99.0",
    "@pluralsh/design-system": "workspace:*",
    "@react-hooks-library/core": "0.6.2",
    "@react-spring/web": "10.1.2",
    "@saas-ui/use-hotkeys": "1.1.3",
    "@sentry/react": "10.63.0",
